{
  "_comment": "Pentest agent permissions. Real safety boundary is scope-check + container sandbox, not per-command prompts. Granular Bash patterns don't match pipe/semicolon chains, so we allow all Bash and rely on the deny list for destructive ops.",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash",
      "Read(/work/**)",
      "Read(/scope/**)",
      "Read(/opt/**)",
      "Read(/root/.claude/**)",
      "Read(/usr/share/**)",
      "Read(/tmp/**)",
      "Write(/work/**)",
      "Edit(/work/**)",
      "Write(/tmp/**)",
      "Edit(/tmp/**)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /etc:*)",
      "Bash(rm -rf /root:*)",
      "Bash(rm -rf /opt:*)",
      "Bash(rm -rf /scope:*)",
      "Bash(rm -rf /usr:*)",
      "Bash(rm -rf /var:*)",
      "Bash(rm -rf /home:*)",
      "Bash(dd if=/dev:*)",
      "Bash(mkfs:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(init :*)",
      "Bash(:(){ :|: &};:*)",

      "Write(/scope/**)",
      "Write(/etc/**)",
      "Write(/root/.claude/skills/**)",
      "Write(/usr/**)",
      "Write(/opt/**)",
      "Write(/var/**)",
      "Edit(/scope/**)",
      "Edit(/etc/**)",
      "Edit(/root/.claude/skills/**)",
      "Edit(/usr/**)",
      "Edit(/opt/**)"
    ]
  }
}
